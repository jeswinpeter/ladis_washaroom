<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="14dp"
        android:alpha="0.3"
        android:background="?attr/colorOnSurfaceVariant" />

    <!-- Mode toggle pill -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_mode_pill"
        android:orientation="horizontal"
        android:padding="3dp">

        <Button
            android:id="@+id/btnDriving"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/selector_mode_tab"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="🚗  Driving"
            android:textSize="13sp"
            android:textColor="@color/selector_tab_text" />   <!-- ← add this line -->

        <Button
            android:id="@+id/btnTransit"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/selector_mode_tab"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="🚌  Transit"
            android:textSize="13sp"
            android:textColor="@color/selector_tab_text" />   <!-- ← add this line -->
    </LinearLayout>

    <!-- DRIVING VIEW -->
    <LinearLayout
        android:id="@+id/drivingView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Route header card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Route info"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvRouteNameDriving"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating..."
                android:textColor="?attr/colorOnSurface"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDurationDriving"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="?attr/colorSurfaceVariant" />

        <!-- Turn-by-turn steps -->
        <LinearLayout
            android:id="@+id/stepsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp" />

    </LinearLayout>

    <!-- TRANSIT VIEW -->
    <LinearLayout
        android:id="@+id/transitView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Route header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transit route"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvRouteNameTransit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Searching..."
                android:textColor="?attr/colorOnSurface"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDurationTransit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="?attr/colorSurfaceVariant" />

        <!-- Legs -->
        <LinearLayout
            android:id="@+id/legsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/colorSurfaceVariant" />

        <!-- Sun advice -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvSitSideBadge"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/badge_background"
                android:gravity="center"
                android:text="–"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvSitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculating..."
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSunPosition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="–"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvRecommendation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Awaiting route data..."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>